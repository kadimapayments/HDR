# Slack incoming-webhook URLs (one per channel)
SLACK_WEBHOOK_LEADS=
SLACK_WEBHOOK_SERVICE=

# Resend (transactional email) — sign up at resend.com
RESEND_API_KEY=
EMAIL_FROM="HDR Windows <noreply@hdrwindows.com>"

# Where leads / service tickets get emailed (overrides the defaults in lib/constants.ts)
LEADS_EMAIL_TO=info@hdrwindows.com
SERVICE_EMAIL_TO=service@hdrwindows.com
